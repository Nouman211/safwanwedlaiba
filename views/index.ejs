<%- include('partials/header') %>

<main>
  <div class="bismillah-banner">
    <div class="container">
      <p class="bismillah-text"><%= t('bismillah') %></p>
    </div>
  </div>

  <!-- ===== Home Section ===== -->
  <section id="home" class="hero" style="background-image: url('https://images.unsplash.com/photo-1519741497674-611481863552?w=1600'); background-size: cover; background-position: center;">
    <div class="hero-overlay" style="background: rgba(26,10,14,0.75);"></div>
    <div class="hero-content">
      <p class="hero-subtitle"><%= t('invite_title') %></p>
      <div class="hero-names">
        <span class="name">Safwan</span>
        <span class="ampersand"><%= t('weds') %></span>
        <span class="name">Laiba</span>
      </div>
      <p class="hero-verse"><%= t('verse') %></p>
      <div class="hero-countdown">
        <div class="countdown-item">
          <span class="countdown-number"><%= days %></span>
          <span class="countdown-label"><%= t('days') %></span>
        </div>
        <div class="countdown-item">
          <span class="countdown-number"><%= hours %></span>
          <span class="countdown-label"><%= t('hours') %></span>
        </div>
        <div class="countdown-item">
          <span class="countdown-number"><%= minutes %></span>
          <span class="countdown-label"><%= t('minutes') %></span>
        </div>
      </div>
    </div>
  </section>

  <section class="section story-section">
    <div class="container">
      <h2 class="section-title"><%= t('our_story') %></h2>
      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <h3><%= t('how_we_met') %></h3>
            <p><%= t('how_we_met_desc') %></p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <h3><%= t('beautiful_discovery') %></h3>
            <p><%= t('beautiful_discovery_desc') %></p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <h3><%= t('the_wedding') %></h3>
            <p><%= t('the_wedding_desc') %></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Events Section ===== -->
  <section id="events" class="section">
    <div class="container">
      <h2 class="section-title"><%= t('wedding_events') %></h2>
      <p class="section-subtitle"><%= t('events_subtitle') %></p>
      <div class="events-timeline">
        <% events.forEach(function(event, index) { %>
          <% 
            var eventImages = [
              'https://i.postimg.cc/2SsyddpT/Chat-GPT-Image-Jul-11-2026-11-04-23-PM.png',
              'https://i.postimg.cc/7ZH8Ff3x/Chat-GPT-Image-Jul-11-2026-11-13-47-PM.png',
              'https://i.postimg.cc/Z52HrQK7/Chat-GPT-Image-Jul-11-2026-11-17-14-PM.png'
            ];
          %>
          <div class="event-card">
            <div class="event-number"><%= index + 1 %></div>
            <div class="event-body">
              <div class="event-image-col">
                <img src="<%= eventImages[index] %>" alt="<%= lang === 'ur' ? event.title_ur : event.title_en %>" class="event-image">
                <div class="event-image-overlay"></div>
              </div>
              <div class="event-text-col">
                <div class="event-icon">
                  <% if (event.icon === 'hand') { %>
                    <i class="fas fa-hand-holding-heart"></i>
                  <% } else if (event.icon === 'ring') { %>
                    <i class="fas fa-ring"></i>
                  <% } else { %>
                    <i class="fas fa-utensils"></i>
                  <% } %>
                </div>
                <h2><%= lang === 'ur' ? event.title_ur : event.title_en %></h2>
                <div class="event-details">
                  <p><i class="fas fa-calendar-day"></i> <%= event.date %></p>
                  <p><i class="fas fa-clock"></i> <%= event.time %></p>
                  <p><i class="fas fa-map-marker-alt"></i> <%= (event.venue === 'Will be decided later') ? t('venue_tbd') : event.venue %></p>
                </div>
                <p class="event-description"><%= lang === 'ur' ? event.description_ur : event.description %></p>
                <% if (event.venue !== 'Will be decided later' && event.venue !== 'بعد میں طے ہوگا') { %>
                  <a href="https://maps.google.com/?q=<%= encodeURIComponent(event.venue) %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline"><%= t('view_on_map') %> <i class="fas fa-external-link-alt"></i></a>
                <% } %>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="section mehndi-names-section">
    <div class="container">
      <h3 class="section-title" style="font-size:1.8rem;"><%= lang === 'ur' ? 'بے تابی سے انتظار' : 'Awaiting Eyes' %></h3>
      <div class="mehndi-names-pyramid">
        <div class="mehndi-names-row">
          <div class="mini-guest-card"><div class="mini-avatar" style="background:linear-gradient(135deg,var(--gold),var(--gold-dark))">W</div><span>Washma Lodhi</span></div>
          <div class="mini-guest-card"><div class="mini-avatar" style="background:linear-gradient(135deg,var(--peach),#d4733a)">U</div><span>Umama Lodhi</span></div>
        </div>
        <div class="mehndi-names-row">
          <div class="mini-guest-card"><div class="mini-avatar" style="background:linear-gradient(135deg,var(--rose),#c0392b)">R</div><span>Rabia Nouman</span></div>
          <div class="mini-guest-card"><div class="mini-avatar" style="background:linear-gradient(135deg,var(--lavender),var(--berry))">M</div><span>Mirha Lodhi</span></div>
          <div class="mini-guest-card"><div class="mini-avatar" style="background:linear-gradient(135deg,var(--teal),#1abc9c)">M</div><span>Manha Lodhi</span></div>
        </div>
        <div class="mehndi-names-row">
          <div class="mini-guest-card"><div class="mini-avatar" style="background:linear-gradient(135deg,var(--sage),#6ab04c)">P</div><span>Paro Majid</span></div>
          <div class="mini-guest-card"><div class="mini-avatar" style="background:linear-gradient(135deg,var(--orange),#e17055)">F</div><span>Fatima Lodhi</span></div>
          <div class="mini-guest-card"><div class="mini-avatar" style="background:linear-gradient(135deg,var(--coral),#eb4d4b)">R</div><span>Rumaisa Lodhi</span></div>
        </div>
        <div class="mehndi-names-row">
          <div class="mini-guest-card"><div class="mini-avatar" style="background:linear-gradient(135deg,var(--sky),#0984e3)">S</div><span>Safa Lodhi</span></div>
          <div class="mini-guest-card"><div class="mini-avatar" style="background:linear-gradient(135deg,var(--gold),#b8864a)">E</div><span>Eshmal Lodhi</span></div>
          <div class="mini-guest-card"><div class="mini-avatar" style="background:linear-gradient(135deg,var(--rose-light),var(--rose))">M</div><span>Maryam Lodhi</span></div>
        </div>
        <div class="mehndi-names-row">
          <div class="mini-guest-card"><div class="mini-avatar" style="background:linear-gradient(135deg,var(--lavender-light),var(--lavender))">F</div><span>Fatima Shahid</span></div>
        </div>
      </div>
    </div>
  </section>
  <section id="rsvp" class="page-hero">
    <div class="container">
      <h1><%= t('rsvp_title') %></h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="family-contacts-columns">
        <div class="family-contacts-col">
          <div class="guest-card">
            <div class="guest-avatar" style="background:linear-gradient(135deg,var(--gold),var(--gold-dark))">M</div>
            <div class="guest-info">
              <h3>Mr & Mrs M. Rasheed Lodhi</h3>
              <span class="guest-relation"><i class="fas fa-phone"></i> 0300-8548210</span>
            </div>
          </div>
          <div class="guest-card">
            <div class="guest-avatar" style="background:linear-gradient(135deg,var(--rose),#c0392b)">S</div>
            <div class="guest-info">
              <h3>Mr & Mrs M. Shahzad Lodhi</h3>
            </div>
          </div>
          <div class="guest-card">
            <div class="guest-avatar" style="background:linear-gradient(135deg,var(--teal),#1abc9c)">N</div>
            <div class="guest-info">
              <h3>Mr & Mrs M. Nouman Rasheed</h3>
              <span class="guest-relation"><i class="fas fa-phone"></i> 0321-4278926</span>
            </div>
          </div>
        </div>
        <div class="family-contacts-col">
          <div class="guest-card">
            <div class="guest-avatar" style="background:linear-gradient(135deg,var(--peach),#d4733a)">I</div>
            <div class="guest-info">
              <h3>Mr & Mrs Inam Ul Haq Lodhi</h3>
            </div>
          </div>
          <div class="guest-card">
            <div class="guest-avatar" style="background:linear-gradient(135deg,var(--lavender),var(--berry))">E</div>
            <div class="guest-info">
              <h3>Mr & Mrs Ehsan Ul Haq Lodhi</h3>
            </div>
          </div>
          <div class="guest-card">
            <div class="guest-avatar" style="background:linear-gradient(135deg,var(--sage),#6ab04c)">I</div>
            <div class="guest-info">
              <h3>Mr & Mrs Ikram Ul Haq Lodhi</h3>
            </div>
          </div>
          <div class="guest-card">
            <div class="guest-avatar" style="background:linear-gradient(135deg,var(--orange),#e17055)">U</div>
            <div class="guest-info">
              <h3>Mr & Mrs Usman Lodhi</h3>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Guests Section ===== -->
  <section id="guests" class="page-hero">
    <div class="container">
      <h1><%= t('guest_list') %></h1>
      <p><%= t('guest_subtitle') %></p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="guest-count" style="text-align:center;margin-bottom:20px;">
        <p><%= guests.length %> <%= t('guest') %></p>
      </div>

      <div class="guest-grid">
        <% guests.forEach(function(guest) { %>
          <div class="guest-card">
            <div class="guest-avatar">
              <%= guest.name.charAt(0) %>
            </div>
            <div class="guest-info">
              <h3><%= guest.name %></h3>
              <span class="guest-relation"><%= lang === 'ur' ? t(guest.relation.toLowerCase()) : guest.relation %></span>
            </div>
            <span class="guest-status status-<%= guest.status.toLowerCase() %>">
              <% if (guest.status === 'Confirmed') { %>
                <i class="fas fa-check-circle"></i>
              <% } else if (guest.status === 'Invited') { %>
                <i class="fas fa-envelope"></i>
              <% } else { %>
                <i class="fas fa-hourglass-half"></i>
              <% } %>
              <%= lang === 'ur' ? (guest.status === 'Invited' ? t('invited_status') : guest.status) : guest.status %>
            </span>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- ===== Gallery Section ===== -->
  <section id="gallery" class="page-hero">
    <div class="container">
      <h1><%= t('gallery_title') %></h1>
      <p><%= t('gallery_subtitle') %></p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="gallery-placeholder">
        <i class="fas fa-images"></i>
        <h2><%= t('gallery_coming_soon') %></h2>
        <p><%= t('gallery_coming_soon_desc') %></p>
      </div>
      <div class="gallery-grid" style="display:none">
        <% images.forEach(function(image) { %>
          <div class="gallery-item">
            <% if (image.url) { %>
              <img src="<%= image.url %>" alt="<%= image.caption %>" loading="lazy">
              <div class="gallery-overlay">
                <span><%= image.caption %></span>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="section countdown-section">
    <div class="container">
      <div class="countdown-decorative"><i class="fas fa-heart"></i></div>
      <h2 class="countdown-heading"><%= t('countdown_title') || 'Forever Begins In' %></h2>
      <div class="countdown-timer" id="countdownTimer">
        <div class="countdown-unit">
          <span class="countdown-number" id="countDays">00</span>
          <span class="countdown-label"><%= t('days') || 'Days' %></span>
        </div>
        <div class="countdown-separator"><i class="fas fa-heart"></i></div>
        <div class="countdown-unit">
          <span class="countdown-number" id="countHours">00</span>
          <span class="countdown-label"><%= t('hours') || 'Hours' %></span>
        </div>
        <div class="countdown-separator"><i class="fas fa-heart"></i></div>
        <div class="countdown-unit">
          <span class="countdown-number" id="countMinutes">00</span>
          <span class="countdown-label"><%= t('minutes') || 'Minutes' %></span>
        </div>
        <div class="countdown-separator"><i class="fas fa-heart"></i></div>
        <div class="countdown-unit">
          <span class="countdown-number" id="countSeconds">00</span>
          <span class="countdown-label"><%= t('seconds') || 'Seconds' %></span>
        </div>
      </div>
      <p class="countdown-date"><i class="fas fa-calendar-heart"></i> <%= t('countdown_date') %></p>
      <div class="countdown-quote">
        <p><%= t('countdown_quote') %></p>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>